modules = ["python-3.11", "postgresql-16"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["freetype", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "tcl", "tk", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python launcher.py"

[userenv]

[userenv.shared]
AI_BACKEND = "groq"
OLLAMA_BASE_URL = "http://localhost:11434"
OLLAMA_MODEL = "gemma3:12b"
OLLAMA_VISION_MODEL = "gemma3:12b"
CF_IMAGE_MODEL = "flux"
COMFYUI_MODE = "multiref"
COMFYUI_URL = "https://gina-fatherless-shavonda.ngrok-free.dev"
IMAGE_BACKEND = "comfyui"
COMFYUI_USE_SAM = "false"
COMFYUI_GGUF = "flux-2-klein-4b-Q5_K_M.gguf"
COMFYUI_VAE = "flux2-vae.safetensors"
COMFYUI_CLIP = "qwen_3_4b.safetensors"
COMFYUI_STEPS = "4"
COMFYUI_WIDTH = "512"
COMFYUI_HEIGHT = "512"
COMFYUI_CLIP_VISION = "pytorch_model.bin"
